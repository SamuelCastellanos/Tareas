        "def compute_factorial(num):\n",
        "    if num == 0 or num == 1:\n",
        "        return 1\n",
        "    else:\n",
        "        result = 1\n",
        "        for i in range(1, num + 1):\n",
        "            result *= i\n",
        "        return result\n",
        "print(compute_factorial(5))"
      ],
